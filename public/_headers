# Immutable hashed assets (JS, CSS) — cache forever, revalidate on new deploy
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images and fonts in /assets
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable

# Static files that don't change often
/*.png
  Cache-Control: public, max-age=86400
/*.ico
  Cache-Control: public, max-age=86400
/manifest.json
  Cache-Control: public, max-age=86400

# Service worker must never be cached so updates roll out immediately
/sw.js
  Cache-Control: no-store

# HTML — short cache, revalidate so users always get latest shell
/*
  Cache-Control: public, max-age=0, must-revalidate
