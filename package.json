{
  "name": "skip-and-loafer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "cloudflare:assetsignore": "node scripts/write-cloudflare-assetsignore.js",
    "cloudflare:dev": "npm run build && npm run cloudflare:assetsignore && wrangler dev",
    "cloudflare:deploy": "npm run build && npm run cloudflare:assetsignore && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply skip-and-loafer --local",
    "db:migrate:remote": "wrangler d1 migrations apply skip-and-loafer --remote",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:pwa": "node scripts/run-pwa-smoke.mjs",
    "test:webkit": "playwright test --project=webkit",
    "test:webkit:ui": "playwright test --project=webkit --ui",
    "test:webkit:headed": "playwright test --project=webkit --headed"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tailwindcss/postcss": "^4.1.18",
    "framer-motion": "^12.27.5",
    "gif.js": "^0.2.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.1.18",
    "vite": "^8.0.16",
    "wrangler": "^4.53.0"
  }
}
